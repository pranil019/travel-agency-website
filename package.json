{
  "name": "travel-agency-website",
  "version": "1.0.0",
  "description": "A functional travel agency website built with Node.js, Express, and MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:client": "npm --prefix client run dev",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "build:client": "npm --prefix client run build"
  },
  "keywords": ["travel", "express", "mongodb", "nodejs"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.3",
    "ejs": "^3.1.8",
    "dotenv": "^16.0.3",
    "body-parser": "^1.20.2",
    "express-session": "^1.17.3",
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^2.0.20"
  }
}

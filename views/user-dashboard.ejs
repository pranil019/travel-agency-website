<%- include('partials/header') %>

<div class="container dashboard-container">
  <div class="dashboard-header">
    <h1>Welcome, <%= user.name %></h1>
    <p class="muted-text">Browse packages and keep track of your recent bookings.</p>
  </div>

  <div class="dashboard-grid">
    <section class="dashboard-card">
      <h2>Available Packages</h2>

      <% if (packages && packages.length > 0) { %>
        <div class="packages-grid">
          <% packages.forEach(pkg => { %>
            <div class="package-card">
              <div class="package-header">
                <h3><%= pkg.name %></h3>
                <span class="badge"><%= pkg.destination %></span>
              </div>
              <p class="description"><%= pkg.description %></p>
              <div class="package-info">
                <div class="info-item">
                  <span class="label">Duration:</span>
                  <span class="value"><%= pkg.duration %> days</span>
                </div>
                <div class="info-item">
                  <span class="label">Price:</span>
                  <span class="value price">$<%= pkg.price.toFixed(2) %></span>
                </div>
              </div>
              <a href="/packages/details/<%= pkg._id %>" class="btn-primary">View Details</a>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p>No packages available yet.</p>
      <% } %>
    </section>

    <section class="dashboard-card">
      <h2>Recent Bookings</h2>

      <% if (myRecentBookings && myRecentBookings.length > 0) { %>
        <div class="bookings-list compact">
          <% myRecentBookings.forEach(booking => { %>
            <div class="booking-card">
              <div class="booking-header">
                <h3><%= booking.packageId ? booking.packageId.name : 'Package' %></h3>
                <span class="status-badge status-<%= booking.status %>"><%= booking.status.toUpperCase() %></span>
              </div>
              <div class="booking-details">
                <div class="detail-row">
                  <span class="label">People:</span>
                  <span class="value"><%= booking.numberOfPeople %></span>
                </div>
                <div class="detail-row">
                  <span class="label">Total:</span>
                  <span class="value">$<%= booking.totalPrice.toFixed(2) %></span>
                </div>
              </div>
            </div>
          <% }); %>
        </div>

        <a href="/bookings/my-bookings" class="btn-secondary">View All Bookings</a>
      <% } else { %>
        <p>No bookings yet.</p>
        <a href="/packages" class="btn-primary">Browse Packages</a>
      <% } %>
    </section>
  </div>
</div>

<%- include('partials/footer') %>

